# Semantic Engine B2B - Environment Configuration
# Copy this file to .env and configure

# Server
HOST=0.0.0.0
PORT=8000
DEBUG=false

# Embedding Model
# Options: all-MiniLM-L6-v2, all-mpnet-base-v2, paraphrase-multilingual-MiniLM-L12-v2
EMBEDDING_MODEL=all-MiniLM-L6-v2
USE_GPU=false

# Security (Production)
# API_SECRET_KEY=your-secret-key-here
# ALLOWED_ORIGINS=https://your-domain.com

# API Keys Configuration (REQUIRED for production)
# JSON String format: {"api_key": {"tier": "tier_name", "active": true}}
# Example:
VALID_API_KEYS='{"your_api_key_here": {"tier": "default", "active": true}}'

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=change_me_redis_password

# Qdrant Configuration
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=change_me_qdrant_api_key
